# ===========================================
# RevOps n8n Environment Variables
# ===========================================
# Copy to your n8n environment configuration
# ===========================================

# --- Workflow IDs (set after importing workflows) ---
W02_WORKFLOW_ID=
W05_WORKFLOW_ID=
W06_WORKFLOW_ID=
W08_WORKFLOW_ID=
W09_WORKFLOW_ID=
W12_WORKFLOW_ID=

# --- HubSpot ---
HUBSPOT_API_KEY=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
HUBSPOT_OWNER_SENIOR_REP=123456789
HUBSPOT_OWNER_SALES_REP=123456790
HUBSPOT_OWNER_SDR=123456791

# --- WhatsApp Business API ---
WHATSAPP_API_URL=https://waba.360dialog.io/v1

# --- Slack ---
SLACK_CHANNEL_VIP=#vip-leads
SLACK_CHANNEL_SALES=#sales-leads
SLACK_CHANNEL_SDR=#sdr-queue
SLACK_CHANNEL_WINS=#wins
SLACK_CHANNEL_MANAGEMENT=#management

# --- Email ---
SMTP_FROM_EMAIL=noreply@yourcompany.com

# --- Google Sheets ---
GOOGLE_SHEET_AUDIT_ID=your-google-sheet-id-for-audit
GOOGLE_SHEET_FORECAST_ID=your-google-sheet-id-for-forecast

# --- Thresholds ---
VIP_THRESHOLD=10000
